NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL pública do app (QR Code e link da proposta enviados ao cliente)
NEXT_PUBLIC_APP_URL=https://grx-management.vercel.app

# Teste Aceitar/Recusar no celular (mesma Wi-Fi) — IP do npm run dev (Network)
NEXT_PUBLIC_DEV_PUBLIC_URL=http://192.168.15.16:3002

# OCR da CNH (opcional — melhora precisão; sem isso usa Tesseract local)
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# Pedágios automáticos na rota A→B (QualP Pro — https://qualp.com.br/pro/)
QUALP_API_TOKEN=your-qualp-access-token

# Piso ANTT todos os tipos de carga (opcional)
CIOT_ONLINE_API_TOKEN=ciot_your-token
